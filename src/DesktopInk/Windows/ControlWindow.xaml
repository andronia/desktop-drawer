<Window x:Class="DesktopInk.Windows.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopInk.Controls"
        Icon="/Assets/app-icon.ico"
        Width="88"
        Height="494"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EEFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Style.Triggers>
                <!-- Draw mode active: Windows Blue -->
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Draw">
                    <Setter Property="Background" Value="#DC0078D4"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Draw"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#EE0078D4"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Style.Triggers>
                <!-- Tool active (e.g., highlighter selected): amber -->
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Active">
                    <Setter Property="Background" Value="#DCE6A700"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Active"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#EEE6A700"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FadeToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Style.Triggers>
                <!-- Fade active: teal -->
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Active">
                    <Setter Property="Background" Value="#DC14B8A6"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Active"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#EE14B8A6"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SpotlightToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Style.Triggers>
                <!-- Spotlight active: purple -->
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Active">
                    <Setter Property="Background" Value="#DC8B5CF6"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Active"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#EE8B5CF6"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="White"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                    <Setter Property="Fill" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SwatchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwatchEllipseStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Stroke" Value="#66FFFFFF"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}" Value="Active">
                    <Setter Property="Stroke" Value="White"/>
                    <Setter Property="StrokeThickness" Value="2.5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Background="#AA000000" CornerRadius="10" Padding="8" Opacity="0.85">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Draw Mode Toggle Button - Pen Icon -->
            <Button x:Name="ToggleButton" Width="36" Height="36" Margin="0,0,0,8"
                    Style="{StaticResource ToggleButtonStyle}"
                    Tag="PassThrough"
                    Click="OnToggleClick" ToolTip="Toggle Draw (Win+Shift+D)&#x0a;Alt+Double-click for temporary mode">
                <Viewbox Width="20" Height="20">
                    <Path x:Name="TogglePath"
                          Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.996.996 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                          Style="{StaticResource IconPathStyle}"/>
                </Viewbox>
            </Button>

            <!-- Highlighter Toggle Button -->
            <Button x:Name="HighlighterButton" Width="36" Height="36" Margin="0,0,0,8"
                    Style="{StaticResource ToolToggleButtonStyle}"
                    Tag="Inactive"
                    Click="OnHighlighterClick" ToolTip="Toggle Highlighter">
                <Viewbox Width="20" Height="20">
                    <Path Data="M17.75 7L14 3.25l-10 10V17h3.75l10-10zm2.96-2.96c.39-.39.39-1.02 0-1.41L18.37.29a.9959.9959 0 0 0-1.41 0L15 2.25 18.75 6l1.96-1.96zM0 20h24v4H0v-4z"
                          Style="{StaticResource IconPathStyle}"/>
                </Viewbox>
            </Button>

            <!-- Rectangle Toggle Button -->
            <Button x:Name="RectangleButton" Width="36" Height="36" Margin="0,0,0,8"
                    Style="{StaticResource ToolToggleButtonStyle}"
                    Tag="Inactive"
                    Click="OnRectangleClick" ToolTip="Toggle Rectangle (Shift = square)">
                <Viewbox Width="20" Height="20">
                    <Path Data="M19 19H5V5h14v14zM19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"
                          Style="{StaticResource IconPathStyle}"/>
                </Viewbox>
            </Button>

            <!-- Arrow Toggle Button -->
            <Button x:Name="ArrowButton" Width="36" Height="36" Margin="0,0,0,8"
                    Style="{StaticResource ToolToggleButtonStyle}"
                    Tag="Inactive"
                    Click="OnArrowClick" ToolTip="Toggle Arrow">
                <Viewbox Width="20" Height="20">
                    <Path Data="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.58L12 20l8-8z"
                          Style="{StaticResource IconPathStyle}"/>
                </Viewbox>
            </Button>

            <!-- Auto-Fade Toggle Button - Timer/history icon -->
            <Button x:Name="FadeButton" Width="36" Height="36" Margin="0,0,0,8"
                    Style="{StaticResource FadeToggleButtonStyle}"
                    Tag="Inactive"
                    Click="OnFadeClick" ToolTip="Auto-Fade Strokes">
                <Viewbox Width="20" Height="20">
                    <Path Data="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6a7 7 0 1 1 2.05 4.95l-1.42 1.43A9 9 0 1 0 13 3zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"
                          Style="{StaticResource IconPathStyle}"/>
                </Viewbox>
            </Button>

            <!-- Cursor Spotlight Toggle - Visibility/eye icon -->
            <Button x:Name="SpotlightButton" Width="36" Height="36" Margin="0,0,0,8"
                    Style="{StaticResource SpotlightToggleButtonStyle}"
                    Tag="Inactive"
                    Click="OnSpotlightClick" ToolTip="Toggle Cursor Spotlight">
                <Viewbox Width="20" Height="20">
                    <Path Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                          Style="{StaticResource IconPathStyle}"/>
                </Viewbox>
            </Button>

            <!-- Thickness Slider (1-10); scroll wheel also adjusts -->
            <Grid Width="72" Margin="0,2,0,10">
                <Slider x:Name="ThicknessSlider"
                        Minimum="1" Maximum="10" Value="4"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        SmallChange="1" LargeChange="1"
                        ToolTip="Brush thickness (scroll to adjust)"
                        ValueChanged="OnThicknessSliderChanged"
                        PreviewMouseWheel="OnThicknessSliderWheel"/>
            </Grid>

            <!-- Color Swatch Grid (3 per row) -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="RedSwatch" Style="{StaticResource SwatchButtonStyle}"
                            Tag="Inactive" Click="OnColorSwatchClick" ToolTip="Red">
                        <Ellipse Style="{StaticResource SwatchEllipseStyle}" Fill="#FF2020"/>
                    </Button>
                    <Button x:Name="BlueSwatch" Style="{StaticResource SwatchButtonStyle}"
                            Tag="Inactive" Click="OnColorSwatchClick" ToolTip="Blue">
                        <Ellipse Style="{StaticResource SwatchEllipseStyle}" Fill="#1E6FFF"/>
                    </Button>
                    <Button x:Name="GreenSwatch" Style="{StaticResource SwatchButtonStyle}"
                            Tag="Inactive" Click="OnColorSwatchClick" ToolTip="Green">
                        <Ellipse Style="{StaticResource SwatchEllipseStyle}" Fill="#22DD55"/>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="YellowSwatch" Style="{StaticResource SwatchButtonStyle}"
                            Tag="Inactive" Click="OnColorSwatchClick" ToolTip="Yellow">
                        <Ellipse Style="{StaticResource SwatchEllipseStyle}" Fill="#FFE61A"/>
                    </Button>
                    <Button x:Name="WhiteSwatch" Style="{StaticResource SwatchButtonStyle}"
                            Tag="Inactive" Click="OnColorSwatchClick" ToolTip="White">
                        <Ellipse Style="{StaticResource SwatchEllipseStyle}" Fill="#FFFFFF"/>
                    </Button>
                    <Button x:Name="MagentaSwatch" Style="{StaticResource SwatchButtonStyle}"
                            Tag="Inactive" Click="OnColorSwatchClick" ToolTip="Magenta">
                        <Ellipse Style="{StaticResource SwatchEllipseStyle}" Fill="#FF2EB5"/>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="OrangeSwatch" Style="{StaticResource SwatchButtonStyle}"
                            Tag="Inactive" Click="OnColorSwatchClick" ToolTip="Orange">
                        <Ellipse Style="{StaticResource SwatchEllipseStyle}" Fill="#FF8A1E"/>
                    </Button>
                    <Button x:Name="CyanSwatch" Style="{StaticResource SwatchButtonStyle}"
                            Tag="Inactive" Click="OnColorSwatchClick" ToolTip="Cyan">
                        <Ellipse Style="{StaticResource SwatchEllipseStyle}" Fill="#22DDE6"/>
                    </Button>
                    <Button x:Name="BlackSwatch" Style="{StaticResource SwatchButtonStyle}"
                            Tag="Inactive" Click="OnColorSwatchClick" ToolTip="Black">
                        <Ellipse Style="{StaticResource SwatchEllipseStyle}" Fill="#101010"/>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Clear Button - Trashcan Icon -->
            <Button Width="36" Height="36" Margin="0,0,0,8"
                    Style="{StaticResource IconButtonStyle}"
                    Click="OnClearClick" ToolTip="Clear (Win+Shift+C)">
                <Viewbox Width="20" Height="20">
                    <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                          Style="{StaticResource IconPathStyle}"/>
                </Viewbox>
            </Button>

            <!-- Quit Button -->
            <Button Width="36" Height="36"
                    Style="{StaticResource IconButtonStyle}"
                    Click="OnQuitClick" ToolTip="Quit (Win+Shift+Q)">
                <Viewbox Width="20" Height="20">
                    <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                          Style="{StaticResource IconPathStyle}"/>
                </Viewbox>
            </Button>
        </StackPanel>
    </Border>
</Window>
